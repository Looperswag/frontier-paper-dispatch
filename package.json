{
  "name": "frontier-papers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "前沿论文情报台 — 多源采集 → Claude 排名/总结 → 每晚邮件 Top5",
  "scripts": {
    "ingest:dry": "tsx scripts/ingest.ts --dry",
    "ingest": "node --env-file=.env --import tsx scripts/ingest.ts",
    "ingest:send": "node --env-file=.env --import tsx scripts/ingest.ts --send",
    "push:last": "node --env-file=.env --import tsx scripts/send-last.ts",
    "test": "node --import tsx --test lib/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "fast-xml-parser": "^5.9.3",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
