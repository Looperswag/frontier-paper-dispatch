# ---- DeepSeek (排名 / 总结 / 影响；OpenAI 兼容协议) ----
DEEPSEEK_API_KEY=sk-...

# ---- Supabase (共享数据库；本地写，云端 UI 读) ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # 仅本地 ingest 用，勿放进前端

# ---- Server酱 (每晚推送到微信) ----
# 去 https://sct.ftqq.com 用微信扫码登录、关注服务号，复制 SendKey 填这里。
# 兼容老版 Turbo(SCT...) 与 Server酱³(sctp...) 两种 key，代码自动适配。
SERVERCHAN_SENDKEY=SCT...

# ---- 可选：抬高 github 未鉴权速率限制 ----
GITHUB_TOKEN=

# ---- 可选：网页深链回前台 ----
WEB_BASE_URL=https://your-app.vercel.app

# ---- 反馈一键链接签名（任意随机串；本地与 Vercel 私有站需一致）----
FEEDBACK_SECRET=
